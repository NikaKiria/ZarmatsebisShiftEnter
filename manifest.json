{
  "manifest_version": 3,
  "name": "Georgian to English Keyboard Converter",
  "version": "1.0",
  "description": "Georgian to English Keyboard Converter _ Detects Georgian keyboard input and suggests English corrections",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "clipboardWrite",
    "clipboardRead"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "geo"
  },
  "commands": {
    "convert-georgian": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Convert Georgian text to English"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Georgian Keyboard Converter"
  },
  "icons": {
    "16": "icon128.png",
    "48": "icon128.png",
    "128": "icon128.png"
  }
}