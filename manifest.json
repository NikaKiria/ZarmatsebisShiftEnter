{
  "manifest_version": 3,
  "name": "Georgian to English Keyboard Converter",
  "version": "1.0",
  "description": "Detects Georgian keyboard input and suggests English corrections",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Georgian Keyboard Converter"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}